# CONTEXT: YOUR production deploy (worker + web). Copy to infra-prod/.env.
# Required values have no safe default; the stack misbehaves until they are set.

# Public origin (the product domain). Drives the worker CORS allow-list and the web app's Better
# Auth base URL. The dashboard is a route group (not an /app path), so this is the bare origin.
PUBLIC_ORIGIN=https://bankstract.logickoder.dev

# How Caddy serves. Empty = ":80" (plain HTTP, for local smoke). Set to your hostname
# (bankstract.logickoder.dev) - DNS points straight at the box (Namecheap, no Cloudflare proxy)
# and Caddy auto-provisions a free Let's Encrypt cert on :443.
SITE_ADDRESS=

# Docs home (Cloudflare Pages subdomain, off this box). Baked into the web bundle so in-app docs
# links resolve. A CNAME at your DNS points it at the Pages project.
DOCS_URL=https://docs.bankstract.logickoder.dev

# REQUIRED. Shared admin token: web proxies admin endpoints to the worker with it. Same value in
# both services. Generate a long random string.
ADMIN_API_TOKEN=

# REQUIRED. Shared demo key: the /demo proxy sends it, the worker matches it. Use a bsk_test_ key.
DEMO_API_KEY=bsk_test_demo_prod

# REQUIRED. Better Auth session-signing secret. 32+ random bytes.
BETTER_AUTH_SECRET=

# Social sign-in. Register the callback as <PUBLIC_ORIGIN>/api/auth/callback/<provider>.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Magic-link email. Empty logs the link to the web server console instead of sending.
RESEND_API_KEY=

# Cloudflare Turnstile (demo anonymous gate). Empty disables verification.
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# Billing: empty = disabled (no charges). Paystack NGN subscriptions, monthly + annual plan codes.
PAYSTACK_SECRET_KEY=
PAYSTACK_PLAN_STARTER=
PAYSTACK_PLAN_GROWTH=
PAYSTACK_PLAN_SCALE=
PAYSTACK_PLAN_STARTER_ANNUAL=
PAYSTACK_PLAN_GROWTH_ANNUAL=
PAYSTACK_PLAN_SCALE_ANNUAL=

# Sentry error reporting (worker + web, server-side, privacy-scrubbed). Empty = off.
SENTRY_DSN=

# Nightly R2 backup. Empty bucket => local snapshots only (no upload).
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=
