# CONTEXT: YOUR production deploy (worker + app + demo). Copy to infra-prod/.env.
# Required values have no safe default; the stack misbehaves until they are set.

# Public origin Cloudflare serves (the product domain). Drives the worker CORS allow-list and
# the app's Better Auth base URL (the app is path-routed under /app).
PUBLIC_ORIGIN=https://bankstract.logickoder.dev

# REQUIRED. Shared admin token: the app proxies admin endpoints to the worker with it. Same value
# in both services. Generate a long random string.
ADMIN_API_TOKEN=

# REQUIRED. Shared demo key: the demo proxy sends it, the worker matches it. Use a bsk_test_ key.
DEMO_API_KEY=bsk_test_demo_prod

# REQUIRED. Better Auth session-signing secret. 32+ random bytes.
BETTER_AUTH_SECRET=

# Social sign-in. Register the callback as <PUBLIC_ORIGIN>/app/api/auth/callback/<provider>.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Magic-link email. Empty logs the link to the app's server console instead of sending.
RESEND_API_KEY=

# Cloudflare Turnstile (demo anonymous gate). Empty disables verification.
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# Billing: empty = disabled (no charges). Paystack NGN subscriptions, monthly + annual plan codes.
PAYSTACK_SECRET_KEY=
PAYSTACK_PLAN_STARTER=
PAYSTACK_PLAN_GROWTH=
PAYSTACK_PLAN_SCALE=
PAYSTACK_PLAN_STARTER_ANNUAL=
PAYSTACK_PLAN_GROWTH_ANNUAL=
PAYSTACK_PLAN_SCALE_ANNUAL=

# Sentry error reporting (worker + app, server-side, privacy-scrubbed). Empty = off.
SENTRY_DSN=

# Nightly R2 backup. Empty bucket => local snapshots only (no upload).
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=
