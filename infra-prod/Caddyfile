# Internal path-router on :80. The shared proxy fronting the box does TLS + hostname routing (see
# README § Topology); this Caddy only splits paths within the product host, so it needs no cert.
:80 {
	# Match the worker's 50 MB cap, with headroom for multipart overhead.
	request_body {
		max_size 52MB
	}

	# B2B API + health probes -> worker. flush_interval -1 keeps the /v1/parse/jobs SSE stream
	# unbuffered so progress events reach direct API clients immediately.
	@worker path /v1/* /healthz /readyz
	handle @worker {
		reverse_proxy worker:8000 {
			flush_interval -1
		}
	}

	# Docs -> Cloudflare Pages (off-box). The docs app's Next basePath /docs namespaces its assets
	# (/docs/_next/*) + search under this one matcher, clear of web's own /_next/*. header_up Host
	# lets Pages resolve the project + its TLS SNI.
	@docs path /docs /docs/*
	handle @docs {
		reverse_proxy https://{$DOCS_UPSTREAM} {
			header_up Host {$DOCS_UPSTREAM}
		}
	}

	# Everything else -> the one web runtime (marketing /, demo /demo, dashboard /dashboard, /api/*).
	# flush_interval -1 keeps the demo's SSE proxy (/api/parse/jobs/*/stream -> worker) unbuffered.
	handle {
		reverse_proxy web:3000 {
			flush_interval -1
		}
	}
}
