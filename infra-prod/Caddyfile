# DNS points straight at this box (Namecheap, no Cloudflare proxy). Set SITE_ADDRESS to the
# hostname (e.g. bankstract.logickoder.dev) and Caddy auto-provisions a free Let's Encrypt cert
# on :443. Docs live on a Cloudflare Pages subdomain (docs.*) and never reach this box.

# SITE_ADDRESS empty -> ":80" (plain HTTP, e.g. local smoke). A hostname -> Caddy-managed TLS.
{$SITE_ADDRESS::80} {
	# Match the worker's 50 MB cap, with headroom for multipart overhead.
	request_body {
		max_size 52MB
	}

	# B2B API + health probes -> worker.
	@worker path /v1/* /healthz /readyz
	handle @worker {
		reverse_proxy worker:8000
	}

	# Docs: a Cloudflare Pages project (off this box), surfaced at the same-domain /docs path. The
	# docs app sets Next basePath /docs, so every route + asset is namespaced under /docs
	# (/docs/_next/*, /docs/api/search) and this one matcher covers it without colliding with the
	# web app's own /_next/*. DOCS_UPSTREAM is the Pages host (e.g. bankstract-docs.pages.dev);
	# header_up Host makes Pages serve the right project + its TLS SNI resolve.
	@docs path /docs /docs/*
	handle @docs {
		reverse_proxy https://{$DOCS_UPSTREAM} {
			header_up Host {$DOCS_UPSTREAM}
		}
	}

	# Everything else -> the one web runtime (marketing /, demo /demo, dashboard /dashboard, /api/*).
	handle {
		reverse_proxy web:3000
	}
}
