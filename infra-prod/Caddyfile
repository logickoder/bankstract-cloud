# Behind Cloudflare (TLS terminated upstream), so plain :80. Marketing + docs live on Cloudflare
# Pages and never reach this box. For a standalone box with its own TLS, replace ":80" with your
# hostname and Caddy auto-provisions a Let's Encrypt cert.

:80 {
	# Match the worker's 50 MB cap, with headroom for multipart overhead.
	request_body {
		max_size 52MB
	}

	# B2B API + health probes -> worker.
	@worker path /v1/* /healthz /readyz
	handle @worker {
		reverse_proxy worker:8000
	}

	# Dashboard. The app image is built with basePath /app, so it owns this prefix end to end.
	handle /app/* {
		reverse_proxy app:3000
	}

	# Everything else -> the consumer demo (served at root; doubles as the product showcase).
	handle {
		reverse_proxy demo:3000
	}
}
