# CONTEXT: local dev of the whole monorepo. ONE env file for every surface.
#   cp .env.example .env   (the repo-root .env is gitignored. NEVER commit the filled copy. Directive 2)
# In dev, all surfaces read this single root .env:
#   worker (FastAPI) -> pydantic env_file resolves to the repo-root .env
#   web + demo (Next) -> `dotenv -e ../../.env` wraps their dev scripts
# Each runtime reads only the vars it needs and ignores the rest.
# Deploys use infra-prod/.env or infra/.env: same variable NAMES, different (real) values.
# Dev keys MUST use test_ / bsk_test_ / sk_test_ prefixes. Never live_ in a checked-out tree.

# ── Shared (MUST hold the same value across surfaces. Defined once, on purpose) ──
# Bearer token gating /v1/keys + the web->worker admin calls. Empty = key management disabled.
ADMIN_API_TOKEN=
# Public demo key: the demo app sends it, the worker matches it. Test key in dev.
DEMO_API_KEY=bsk_test_replace_me
# Cloudflare Turnstile: the worker validates the token (secret), the demo widget renders the site key.
TURNSTILE_SECRET_KEY=test_turnstile_secret
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
# Worker base URL the web + demo POST to (server-side).
WORKER_URL=http://127.0.0.1:8000

# ── Worker (FastAPI) ──
# "development" | "production". Gates log verbosity.
BANKSTRACT_CLOUD_ENV=development
# SQLite path for the metadata-only audit log. Relative paths resolve from CWD (apps/worker).
AUDIT_DB_PATH=./audit.sqlite
# Hard upload ceiling in bytes. 50 MB = 52428800 (PRD open-question B, locked).
MAX_UPLOAD_BYTES=52428800
# Anonymous demo rate limit: parses per window, window length in seconds (50/month per IP).
DEMO_RATE_LIMIT_MAX=50
DEMO_RATE_LIMIT_WINDOW_SECONDS=2592000
# Salt for the demo rate-limit IP hash (the bucket key is sha256(salt + ip), never the raw IP).
# Set a stable random secret in prod. Empty is fine for dev.
RATE_LIMIT_IP_SALT=
# Parse-metadata retention in days. Rows older than this are purged by the background sweep.
AUDIT_RETENTION_DAYS=90
# Comma-separated origins allowed to call the worker (the Next.js apps).
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002
# Error tracking (optional). Empty = disabled. NEVER attach PDF content to events.
SENTRY_DSN=

# ── Web (Next.js dashboard + auth) ──
# Better Auth, self-hosted: users + sessions in our own SQLite. Path resolves from CWD (apps/web).
BETTER_AUTH_SECRET=replace_me_with_32_byte_random
BETTER_AUTH_URL=http://localhost:3002
AUTH_DB_PATH=./data/auth.db
# Social sign-in (provision OAuth apps). Empty disables that provider.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Resend transactional email (magic-link sign-in). Empty = dev logs the link instead of sending.
RESEND_API_KEY=re_test_replace_me

# ── Billing (Paystack, NGN subscriptions; secret is worker-only, web proxies through the worker) ──
# Empty secret => billing disabled (dev no-op, no fake charges). Plan codes are dashboard PLN_ codes.
PAYSTACK_SECRET_KEY=sk_test_replace_me
PAYSTACK_PLAN_STARTER=
PAYSTACK_PLAN_GROWTH=
PAYSTACK_PLAN_SCALE=
# Annual prepay plans (yearly interval, 15% off). Blank disables annual checkout for that tier.
PAYSTACK_PLAN_STARTER_ANNUAL=
PAYSTACK_PLAN_GROWTH_ANNUAL=
PAYSTACK_PLAN_SCALE_ANNUAL=

# ── Public (NEXT_PUBLIC_* are inlined into the client at build time) ──
# Cloudflare Web Analytics beacon token (cookieless, no consent banner). Empty = no analytics.
NEXT_PUBLIC_CF_ANALYTICS_TOKEN=
