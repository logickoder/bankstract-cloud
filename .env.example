# bankstract-cloud. environment template.
# Copy per-app: cp .env.example apps/worker/.env  (NEVER commit the filled copy. Directive 2)
# Public repo. Real secrets live only in .env.production on the host (gitignored).
# Dev keys MUST use test_ / bsk_test_ prefixes. Never live_ in a checked-out tree.

# ─────────────────────────────────────────────────────────────────────────────
# apps/worker (FastAPI)
# ─────────────────────────────────────────────────────────────────────────────

# "development" | "production". Gates Stripe live billing + log verbosity.
BANKSTRACT_CLOUD_ENV=development

# SQLite path for the metadata-only audit log. Relative paths resolve from CWD.
# Schema carries NO payload fields (Directive 1). Never points at network storage.
AUDIT_DB_PATH=./audit.sqlite

# Hard upload ceiling in bytes. 50 MB = 52428800 (PRD open-question B, locked).
MAX_UPLOAD_BYTES=52428800

# Anonymous demo rate limit: requests per window, window length in seconds.
# PRD: 50 parses/month per IP for the anonymous demo surface (30-day window).
DEMO_RATE_LIMIT_MAX=50
DEMO_RATE_LIMIT_WINDOW_SECONDS=2592000

# Comma-separated origins allowed to call the worker (the Next.js apps).
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

# Server-side public demo key the demo app sends on behalf of anonymous users.
# Must be a test key in dev.
DEMO_API_KEY=bsk_test_replace_me

# Bearer token that gates the key-management endpoints (/v1/keys). EMPTY = those
# endpoints are disabled (safe default). Set only where you run admin tooling / the
# dashboard. Never commit a real value.
ADMIN_API_TOKEN=

# DEPRECATED: billing is moving to Paystack NGN subscriptions (see CHANGELOG + PRD
# § Pricing). The worker still reads these until billing.py migrates. Empty = no-op.
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_METER_EVENT_NAME=parses_v1

# Cloudflare Turnstile server secret. validates demo tokens before parse.
TURNSTILE_SECRET_KEY=test_turnstile_secret

# Error tracking (optional). Empty = disabled. NEVER attach PDF content to events.
SENTRY_DSN=

# ─────────────────────────────────────────────────────────────────────────────
# Next.js apps (apps/app, apps/demo, apps/marketing)
# ─────────────────────────────────────────────────────────────────────────────

# Worker base URL the frontends POST /v1/parse to.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Better Auth. apps/app only. Self-hosted: users + sessions in our own SQLite.
BETTER_AUTH_SECRET=replace_me_with_32_byte_random
BETTER_AUTH_URL=http://localhost:3002
AUTH_DB_PATH=./data/auth.db
# Social sign-in (provision OAuth apps). Empty disables that provider.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Paystack. apps/app billing UI (NGN subscriptions, see PRD § Pricing).
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_replace_me
PAYSTACK_SECRET_KEY=sk_test_replace_me

# Cloudflare Turnstile site key. apps/demo + marketing forms (public, safe to ship).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# Resend transactional email. apps/app.
RESEND_API_KEY=re_test_replace_me
# Resend audience id for the Billing launch-notify opt-in. Empty = accept without persisting.
RESEND_AUDIENCE_ID=
