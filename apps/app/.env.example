# apps/app. Copy to .env.local (gitignored). Never commit filled secrets.

# Better Auth. Sessions + users live in our own SQLite (self-host stays self-contained).
BETTER_AUTH_SECRET=replace_me_with_32_byte_random
BETTER_AUTH_URL=http://localhost:3002
AUTH_DB_PATH=./data/auth.db

# Social sign-in (provision OAuth apps; callback /api/auth/callback/<provider>).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Magic-link email. Empty in dev logs the link to the server console instead of sending.
RESEND_API_KEY=

# Resend audience for the Billing "Notify me on launch" opt-in. Empty = accept without persisting.
RESEND_AUDIENCE_ID=

# Worker proxy. The dashboard server attaches ADMIN_API_TOKEN and forwards to /v1/keys.
WORKER_URL=http://localhost:8000
ADMIN_API_TOKEN=
