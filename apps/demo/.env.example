# CONTEXT: local dev of the demo only. Copy to .env.local (gitignored).

# Worker base URL the proxy route forwards /v1/parse to.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Cloudflare Turnstile site key (public, safe to ship). 1x...AA is the always-pass TEST key.
# Provision a real (invisible) site key in Cloudflare for production.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# Public demo API key the proxy attaches server-side. SERVER-ONLY. never NEXT_PUBLIC_.
# Must be a bsk_test_ key in dev. In production this gates the anonymous demo tier;
# pair it with a real worker TURNSTILE_SECRET_KEY or the demo is open to abuse.
DEMO_API_KEY=bsk_test_replace_me

# Sentry error tracking (server-side only). Empty = disabled (no network, no reports).
SENTRY_DSN=
