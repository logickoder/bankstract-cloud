{
  "extends": "@bankstract/tsconfig/nextjs.json",
  "compilerOptions": {
    // A Next app emits no .d.ts. turn off declaration so TS doesn't run the
    // "inferred type isn't portable" check on fumadocs' zod-derived types.
    "declaration": false,
    "declarationMap": false,
    "paths": {
      "@/*": ["./*"],
      "collections/*": ["./.source/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".source/**/*.ts"
  ],
  "exclude": ["node_modules", ".next"]
}
