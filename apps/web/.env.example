# CONTEXT: the one prod web app (/ marketing, /demo, /dashboard). Copy to .env.local (gitignored).
# Route groups share one origin, so auth + demo + marketing env all live here.

# --- Better Auth (dashboard /dashboard, API at /api/auth) ---
# Sessions + users live in our own SQLite (self-host stays self-contained).
BETTER_AUTH_SECRET=replace_me_with_32_byte_random
BETTER_AUTH_URL=http://localhost:3002
AUTH_DB_PATH=./data/auth.db
# Browser auth client base. Empty = same window origin (correct for the single-origin shell).
# Set only if the browser reaches the app on a different origin than the server sees.
NEXT_PUBLIC_BETTER_AUTH_URL=
# Magic-link sign-in. Empty RESEND_API_KEY logs the link to the server console (or this file).
RESEND_API_KEY=
MAGIC_LINK_LOG_FILE=

# Social sign-in (provision OAuth apps; callback /api/auth/callback/<provider>).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Worker proxy (dashboard + demo both forward to the worker) ---
# Use 127.0.0.1 (not localhost): Node tries ::1 first, costing a refused IPv6 round-trip.
WORKER_URL=http://127.0.0.1:8000
# Dashboard attaches ADMIN_API_TOKEN to admin/key-management calls.
ADMIN_API_TOKEN=
# Demo client read path (public). The browser hits this for /v1/parse status display.
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Demo (anonymous /demo) ---
# Public demo API key the proxy attaches server-side. SERVER-ONLY. never NEXT_PUBLIC_.
# Must be a bsk_test_ key in dev; in prod pair with a real worker TURNSTILE_SECRET_KEY.
DEMO_API_KEY=bsk_test_replace_me
# Cloudflare Turnstile site key (public). 1x...AA is the always-pass TEST key.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
# Optional Turnstile widget timeout (ms). Empty = library default.
NEXT_PUBLIC_TURNSTILE_TIMEOUT_MS=

# --- Marketing CTAs (public, build-time) ---
NEXT_PUBLIC_DEMO_URL=https://bankstract.logickoder.dev/demo
NEXT_PUBLIC_DOCS_URL=https://bankstract.logickoder.dev/docs
NEXT_PUBLIC_APP_URL=https://bankstract.logickoder.dev/sign-in

# --- Observability ---
# Sentry error tracking (server-side only). Empty = disabled (no network, no reports).
SENTRY_DSN=
