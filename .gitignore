# secrets. NEVER commit (Directive 2). Public repo.
.env
.env.*
!.env.example
*.pem
*.key

# local scratch / experiments
_local/
_scratch/

# node / next / turbo
node_modules/
.next/
out/
.turbo/
dist/
build/
*.tsbuildinfo
.vercel/

# playwright
test-results/
playwright-report/
playwright/.cache/

# fumadocs generated (regenerated on build from the committed openapi.json)
**/.source/
apps/docs/content/docs/api/

# python / uv (apps/worker)
.venv/
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.pyright/
.mypy_cache/

# worker runtime state. audit DB is metadata-only but still local state.
# Globs cover the WAL-mode sidecars (-wal, -shm, -journal) too.
*.sqlite*
*.sqlite3*
*.db*

# os / editor
.DS_Store
*.swp
.idea/
.vscode/

# apps/web Better Auth local DB (sessions live here in dev/e2e; never commit)
apps/web/data/
apps/web/drizzle/

# Local planning/handoff docs (not shipped)
_handoff/
