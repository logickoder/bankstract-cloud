# infra/ self-host bundle. Copy to .env (gitignored). Never commit the filled copy.

# Shared demo key: the demo proxy sends it, the worker matches it. Use a bsk_test_ key.
DEMO_API_KEY=bsk_test_demo_selfhost

# Public origin Caddy serves on (used for the worker's CORS allow-list).
PUBLIC_ORIGIN=http://localhost

# Cloudflare Turnstile. Leave the secret empty to disable verification (demo accepts
# any token). For a real public deployment set BOTH:
#   - the worker secret (server-side validation)
#   - the public site key (inlined into the demo at build time)
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# Billing: empty = disabled (free self-host, no charges). Paystack NGN subscriptions.
# Plan codes are the dashboard PLN_ codes per paid tier.
PAYSTACK_SECRET_KEY=
PAYSTACK_PLAN_STARTER=
PAYSTACK_PLAN_GROWTH=
PAYSTACK_PLAN_SCALE=
